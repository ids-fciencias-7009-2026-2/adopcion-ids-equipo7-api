  "item": [
    {
      "name": "1) POST - /usuarios/register (OK)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get(\"ts\")) {",
              "  pm.environment.set(\"ts\", Date.now().toString());",
              "}",
              "const ts = pm.environment.get(\"ts\");",
              "pm.environment.set(\"email_ok\", `qa_${ts}@ciencias.unam.mx`);",
              "pm.environment.set(\"password_ok\", \"Test123.\");",
              "pm.environment.set(\"nombre_ok\", \"QA Usuario\");",
              "pm.environment.set(\"cp_ok\", \"04510\");",
              "pm.environment.set(\"token_invalid\", \"token_invalido_\" + ts);",
              "pm.environment.set(\"email_missing\", `missing_${ts}@ciencias.unam.mx`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test(\"Tiene id y email\", function () {",
              "  pm.expect(body).to.have.property(\"id\");",
              "  pm.expect(body.email).to.eql(pm.environment.get(\"email_ok\"));",
              "});",
              "pm.test(\"No expone password\", function () {",
              "  pm.expect(body.password === null || body.password === undefined).to.be.true;",
              "});",
              "pm.environment.set(\"userId_ok\", body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"{{nombre_ok}}\",\n  \"email\": \"{{email_ok}}\",\n  \"codigoPostal\": \"{{cp_ok}}\",\n  \"password\": \"{{password_ok}}\"\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios",
            "register"
          ]
        }
      },
      "response": []
    },
