          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Respuesta contiene message', function () { pm.expect(body.message).to.eql('Welcome'); });",
              "pm.test('Respuesta contiene userId', function () { pm.expect(body.userId).to.be.a('string'); });",
              "// Aseguramos que el userId sea el mismo que el del registro",
              "pm.test('userId coincide con registro', function () { pm.expect(body.userId).to.eql(pm.environment.get('userId')); });"
