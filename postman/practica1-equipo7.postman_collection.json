  "item": [
    {
      "name": "1) POST - /usuarios/register (OK)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Genera datos únicos para que el registro NO choque con registros previos",
              "const ts = Date.now();",
              "pm.environment.set('nombre_ok', 'QA User');",
              "pm.environment.set('email_ok', `qa_${ts}@ciencias.unam.mx`);",
              "pm.environment.set('codigoPostal_ok', '04510');",
              "pm.environment.set('password_ok', 'Test123.');",
              "// Un email que NO exista (para probar 404 en /me)",
              "pm.environment.set('email_missing', `qa_missing_${ts}@ciencias.unam.mx`);",
              "// Un id que NO exista (para probar 404 en /logout)",
              "pm.environment.set('id_missing', `id_missing_${ts}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Tiene id (string)', function () { pm.expect(body.id).to.be.a('string'); });",
              "pm.test('Tiene email (string)', function () { pm.expect(body.email).to.be.a('string'); });",
              "pm.test('Email coincide', function () { pm.expect(body.email).to.eql(pm.environment.get('email_ok')); });",
              "pm.test('No expone password', function () { pm.expect(body.password === null || body.password === undefined).to.be.true; });",
              "// Guardamos el id para logout",
              "pm.environment.set('userId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"{{nombre_ok}}\",\n  \"email\": \"{{email_ok}}\",\n  \"codigoPostal\": \"{{codigoPostal_ok}}\",\n  \"password\": \"{{password_ok}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios",
            "register"
          ]
        }
      },
      "response": []
    },
