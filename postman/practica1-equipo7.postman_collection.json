    {
      "name": "6) GET - /usuarios/me (No existe -> 404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', function () { pm.response.to.have.status(404); });",
              "",
              "// NOTA: este endpoint puede responder 404 SIN cuerpo (ResponseEntity.notFound()).",
              "// Si intentamos pm.response.json() con cuerpo vacío, el Runner se detiene.",
              "let body = null;",
              "try { body = pm.response.json(); } catch (e) { body = null; }",
              "",
              "pm.test('Respuesta vacía o mensaje de no encontrado', function () {",
              "  const text = (pm.response.text() || '').trim().toLowerCase();",
              "  if (body && body.error) {",
              "    pm.expect(String(body.error).toLowerCase()).to.include('not');",
              "  } else {",
              "    // normalmente será vacío",
              "    pm.expect(text.length).to.be.within(0, 50);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/usuarios/me?email={{email_missing}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios",
            "me"
          ],
          "query": [
            {
              "key": "email",
              "value": "{{email_missing}}"
            }
          ]
        }
      },
